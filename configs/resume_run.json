{
  "description": "Reference single-run resume configuration for DBP-JSCC with public-friendly relative paths.",
  "env": {
    "DBG_F0_BARK": "1",
    "DBG_GAN_STATS": "1",
    "DBG_GAN_GRAD": "1"
  },
  "script": "training/train.py",
  "args": {
    "data_root": "./data",
    "batch_size": 8,
    "sequence_length": 400,
    "num_epochs": 2000,
    "lr": 0.0001,
    "snr_min_db": 0,
    "snr_max_db": 10,
    "out_dir": "./runs/resume_experiment",
    "ckpt_dir": "./runs/reference_run/checkpoints",
    "viz_every_steps": 100,
    "viz_max_samples": 2,
    "save_every_steps": 100,
    "resume": "./runs/resume_experiment/checkpoints/checkpoint_latest.pth",
    "log_every_steps": 10,
    "bit_only_eval": true,
    "bit_only_eval_max_samples": 1,
    "vm_channel_adaptive": "ssm",
    "vm_lightweight_config": "all_native",
    "vm_channels": [16, 24, 32, 48],
    "vm_depths": [2, 2, 3, 2],
    "fsk_ber_table": "./artifacts/jscc_ber_table.json",
    "use_wandb": true,
    "wandb_project": "DBP-JSCC",
    "wandb_run_name": "resume_experiment",
    "wandb_log_freq": 10,
    "lambda_f0": 0.6,
    "lambda_vuv": 0.6,
    "lambda_vuv_bce": 0.02,
    "lambda_wave": 0.7,
    "lambda_mel_l1": 0.01,
    "lambda_ceps": 0.15,
    "lambda_ceps_hi": 0.15,
    "lambda_mel_hp": 0.0,
    "mel_hp_low_bins": 16,
    "lambda_f0_smooth": 0.15,
    "lambda_hf_stft": 0.0,
    "lambda_texture_protect": 0.005,
    "texture_hf_start": 40,
    "lambda_mel_hf_l1": 0.01,
    "lambda_wave_mag": 0.0,
    "silence_mel_thr_db": -50,
    "with_hash": true,
    "quantizer_type": "rvq",
    "lambda_vq_c": 0.05,
    "lambda_vq_f": 0.01,
    "rvq_nq_content": 4,
    "rvq_nq_f0": 3,
    "lambda_mel_stats": 0.005,
    "lambda_vq_stats": 0.05,
    "lambda_f0_env": 0.02,
    "lambda_mel_energy": 0.05,
    "hash_bits_content": 2,
    "hash_bits_f0": 4,
    "f0_env_margin_cents": 100,
    "f0_env_window": 5,
    "freeze_content_all": true,
    "with_l2h": true,
    "lambda_l2h_resid": 0.0012,
    "lambda_l2h_decor": 0.003,
    "l2h_low_bins": 18,
    "l2h_improve_margin": 0.15,
    "lambda_gan_adv": 0.04,
    "lambda_gan_fm": 0.08,
    "gan_disc_lr": 0.0001,
    "gan_adv_crop_len": 16000,
    "unfreeze_ceps_map": true,
    "unfreeze_l2h": true,
    "lambda_bark_hf_energy": 0.02,
    "bark_hf_energy_margin_db": 3.0,
    "adv_scope": "vocoder_l2h_ceps",
    "gan_adv_warmup_steps": 2000
  }
}
