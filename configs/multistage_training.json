{
  "description": "Five-stage public training pipeline for DBP-JSCC.",
  "python_bin": "python",
  "run_root": "./runs/multistage_training",
  "append_stage_to_wandb_run_name": true,
  "env": {},
  "base_args": {
    "data_root": "./data",
    "batch_size": 8,
    "sequence_length": 400,
    "num_epochs": 2000,
    "lr": 0.0001,
    "snr_min_db": 0,
    "snr_max_db": 10,
    "viz_every_steps": 500,
    "viz_max_samples": 2,
    "save_every_steps": 500,
    "log_every_steps": 10,
    "vm_channel_adaptive": "ssm",
    "vm_lightweight_config": "all_native",
    "vm_channels": [16, 24, 32, 48],
    "vm_depths": [2, 2, 3, 2],
    "vocoder_ckpt": "./vocoder_pt/vocoder_sq1Ab_adv_50.pth",
    "fsk_ber_table": "./artifacts/jscc_ber_table.json",
    "use_wandb": true,
    "wandb_project": "DBP-JSCC",
    "wandb_run_name": "multistage_training",
    "wandb_log_freq": 10,
    "lambda_f0": 0.6,
    "lambda_vuv": 0.6,
    "lambda_vuv_bce": 0.02,
    "lambda_wave": 0.7,
    "lambda_mel_l1": 0.01,
    "lambda_ceps": 0.15,
    "lambda_ceps_hi": 0.15,
    "lambda_mel_hp": 0.0,
    "mel_hp_low_bins": 16,
    "lambda_f0_smooth": 0.15,
    "lambda_hf_stft": 0.0,
    "lambda_texture_protect": 0.005,
    "texture_hf_start": 40,
    "lambda_mel_hf_l1": 0.01,
    "lambda_wave_mag": 0.0,
    "silence_mel_thr_db": -50,
    "quantizer_type": "rvq",
    "lambda_vq_c": 0.05,
    "lambda_vq_f": 0.01,
    "rvq_nq_content": 4,
    "rvq_nq_f0": 3,
    "lambda_mel_stats": 0.005,
    "lambda_vq_stats": 0.05,
    "lambda_f0_env": 0.02,
    "lambda_mel_energy": 0.05,
    "hash_bits_content": 2,
    "hash_bits_f0": 4,
    "f0_env_margin_cents": 100,
    "f0_env_window": 5,
    "lambda_l2h_resid": 0.0012,
    "lambda_l2h_decor": 0.003,
    "l2h_low_bins": 18,
    "l2h_improve_margin": 0.15,
    "lambda_gan_adv": 0.0,
    "lambda_gan_fm": 0.0,
    "gan_adv_warmup_steps": 0,
    "gan_disc_lr": 0.0001,
    "gan_adv_crop_len": 16000,
    "lambda_bark_hf_energy": 0.02,
    "bark_hf_energy_margin_db": 3.0,
    "adv_scope": "vocoder_l2h_ceps",
    "bit_only_eval": false,
    "bit_only_eval_max_samples": 1,
    "with_hash": false,
    "with_l2h": false
  },
  "stages": [
    {
      "name": "content_pretrain",
      "run_steps": 5000,
      "args": {
        "content_only": true,
        "with_hash": false,
        "with_l2h": false,
        "bit_only_eval": false,
        "lambda_gan_adv": 0.0,
        "lambda_gan_fm": 0.0,
        "gan_adv_warmup_steps": 0
      }
    },
    {
      "name": "f0_vuv_alignment",
      "run_steps": 10000,
      "args": {
        "content_only": false,
        "with_hash": false,
        "with_l2h": false,
        "reload_vocoder_after_resume": true,
        "freeze_content_all": true,
        "freeze_vocoder_all": true,
        "bit_only_eval": false,
        "lambda_gan_adv": 0.0,
        "lambda_gan_fm": 0.0,
        "gan_adv_warmup_steps": 0
      }
    },
    {
      "name": "rvq_tuning",
      "run_steps": 10000,
      "args": {
        "with_hash": true,
        "quantizer_type": "rvq",
        "reload_vocoder_after_resume": true,
        "freeze_content_all": false,
        "freeze_vocoder_all": true,
        "vq_only_train": true,
        "with_l2h": false,
        "bit_only_eval": false,
        "lambda_gan_adv": 0.0,
        "lambda_gan_fm": 0.0,
        "gan_adv_warmup_steps": 0
      }
    },
    {
      "name": "l2h_branch_tuning",
      "run_steps": 10000,
      "args": {
        "with_hash": true,
        "with_l2h": true,
        "vq_only_train": false,
        "reload_vocoder_after_resume": true,
        "freeze_content_all": true,
        "freeze_vocoder_all": true,
        "unfreeze_ceps_map": true,
        "unfreeze_l2h": true,
        "bit_only_eval": false,
        "lambda_gan_adv": 0.0,
        "lambda_gan_fm": 0.0,
        "gan_adv_warmup_steps": 0
      }
    },
    {
      "name": "full_vocoder_finetune",
      "run_steps": 20000,
      "args": {
        "with_hash": true,
        "with_l2h": true,
        "reload_vocoder_after_resume": false,
        "freeze_content_all": true,
        "freeze_vocoder_all": false,
        "unfreeze_ceps_map": true,
        "unfreeze_l2h": true,
        "bit_only_eval": true,
        "viz_every_steps": 100,
        "save_every_steps": 100,
        "lambda_gan_adv": 0.04,
        "lambda_gan_fm": 0.08,
        "gan_adv_warmup_steps": 2000
      },
      "env": {
        "DBG_F0_BARK": "1",
        "DBG_GAN_STATS": "1",
        "DBG_GAN_GRAD": "1"
      }
    }
  ]
}
